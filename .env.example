# Anthropic API key. When set (and CHRONOLOOM_ENGINE is empty), the live Claude
# engine drives the simulation. Leave empty to play on the offline scripted engine.
ANTHROPIC_API_KEY=

# Claude model id (bare alias, no date suffix).
CHRONOLOOM_MODEL=claude-opus-4-8

# Engine override: claude | scripted | (empty = auto: claude if key present, else scripted)
CHRONOLOOM_ENGINE=

# When a live Claude turn fails after retries, finish the turn on the scripted
# engine instead of returning an error to the player.
CHRONOLOOM_FALLBACK=true

PORT=8787
