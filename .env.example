# --- Model providers (set any; unset providers show as disabled on the landing page) ---

# Anthropic API key. When set (and CHRONOLOOM_ENGINE is empty), the live Claude
# engine drives the simulation — the primary, highest-quality option.
ANTHROPIC_API_KEY=

# OpenAI API key (GPT provider).
OPENAI_API_KEY=

# DeepSeek API key (OpenAI-compatible surface at https://api.deepseek.com).
DEEPSEEK_API_KEY=

# Model ids.
CHRONOLOOM_MODEL=claude-opus-4-8
CHRONOLOOM_OPENAI_MODEL=gpt-5.1
CHRONOLOOM_DEEPSEEK_MODEL=deepseek-chat

# Default engine override: claude | openai | deepseek | scripted
# (empty = auto: claude > openai > deepseek by available key, else scripted).
# Players can still pick any configured provider on the landing page.
CHRONOLOOM_ENGINE=

# When a live turn fails after retries, finish the turn on the scripted
# engine instead of returning an error to the player.
CHRONOLOOM_FALLBACK=true

PORT=8787
