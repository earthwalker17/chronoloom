{
  "name": "chronoloom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChronoLoom — AI alternate-life simulator. First slice: Tang Chang'an, Lantern Festival week.",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e-playthrough.ts",
    "test:live": "tsx scripts/live-turn.ts",
    "build": "npm run typecheck && vite build",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
