    "rumors": [
      {
        "id": "rumor_seed_1",
        "textZh": "崔家绢行的账册短了一页，行里人人自危。"
      },
      {
        "id": "rumor_seed_2",
        "textZh": "沈记书肆十七夜设灯下诗会，听说有贵人微服要来。"
      },
      {
        "id": "rumor_seed_3",
        "textZh": "波斯邸一笔大货款悬着没结，胡商放话：灯节之内必要个说法。"
      },
      {
        "id": "rumor_1_4",
        "textZh": "那个胡人译语的安四郎，灯节头一日就自己走进了市署。"
      },
      {
        "id": "rumor_2_5",
        "textZh": "绢行短的那页账，怕是与波斯邸的悬款一脉相连，牵线的译语人难脱干系。"
      },
      {
        "id": "rumor_3_6",
        "textZh": "波斯邸那笔悬款，卡在崔家绢行迟迟不出的一张验货回执上。"
      }
    ]
  },
